# Azure AD Service Principal Credentials
AZURE_TENANT_ID=your_azure_tenant_id_here
AZURE_CLIENT_ID=your_azure_client_id_here
AZURE_CLIENT_SECRET=your_azure_client_secret_here

# Power BI REST API Configuration
POWERBI_API_URL=https://api.powerbi.com
POWERBI_SCOPE=https://analysis.windows.net/powerbi/api/.default
POWERBI_WORKSPACE_ID=your_default_workspace_id_here

# Server Configuration
PORT=5000
NODE_ENV=production
FRONTEND_URL=http://localhost:5173

# Anthropic API Credentials (no longer used by migration route, kept for potential future use)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Domo MCP Python Client Settings
DOMO_MCP_SCRIPT_PATH=absolute/path/to/domo_mcp_client.py
DOMO_CLIENT_DOMAIN=gwcteq-partner.domo.com
DOMO_CLIENT_TOKEN=your_domo_token
DOMO_AGENT_EMAIL=your_email@gwcdata.ai
DOMO_AGENT_ROLE=deployer
